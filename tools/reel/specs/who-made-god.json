      {"t": "begins to exist", "c": "gold", "f": "serifb", "s": 60},
      {"t": "has a cause.", "c": "gold", "f": "serifb", "s": 60} ] },
    { "kicker": "THINGS DON'T COME FROM NOTHING", "dur": 4.4, "lines": [
      {"t": "The universe, it seems,", "c": "cream", "s": 52},
