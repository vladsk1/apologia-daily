{
  "crons": [
    {
      "path": "/api/weekly-email?secret=apologia-cron-2026",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/push?do=send&secret=apologia-cron-2026",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    { "source": "/today", "destination": "/today.html" }
  ],
  "redirects": [
    { "source": "/ask-anything.html", "destination": "/asked-and-answered.html", "permanent": true },
    { "source": "/daily-argument.html", "destination": "/today", "permanent": true },
    { "source": "/argument-or-fallacy.html", "destination": "/games.html", "permanent": true },
    { "source": "/CLAUDE.md", "destination": "/", "permanent": false },
    { "source": "/HANDOFF.md", "destination": "/", "permanent": false },
    { "source": "/docs/:path*", "destination": "/", "permanent": false },
    { "source": "/tools/:path*", "destination": "/", "permanent": false },
    { "source": "/.claude/:path*", "destination": "/", "permanent": false }
  ]
}
